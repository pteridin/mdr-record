# Copy this file to .env and fill in the values.

# Stream URL to record from
STREAM_URL=https://example.com/stream/master.m3u8

# When to start the recording. Format: "HH:MM" (today) or "YYYY-MM-DD HH:MM"
# Leave empty to start immediately when the container starts.
START_TIME=

# Duration of the recording in minutes
DURATION_MIN=60

# Base name for the output file
TITLE=my_recording

# Seconds to wait before reconnecting after a dropped stream. Defaults to 10.
RETRY_WAIT=10

# Host directory where recordings are saved
RECORDINGS_DIR=/path/to/recordings

# Timezone used for START_TIME interpretation
TZ=Europe/Berlin
